# =============================================================================
# SalesPulse CRM — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env to git.
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required for both API server and DB migrations)
DATABASE_URL=postgresql://user:password@host:5432/salespulse_crm

# ── Auth ──────────────────────────────────────────────────────────────────────
# JWT signing secret — generate a strong random string (min 32 chars)
# Example: openssl rand -base64 32
SESSION_SECRET=replace-with-a-strong-random-secret-min-32-chars

# ── API Server ────────────────────────────────────────────────────────────────
# Port the Express API server listens on
PORT=8080

# Comma-separated list of allowed CORS origins (production)
# Example: https://yourapp.vercel.app,https://yourcustomdomain.com
ALLOWED_ORIGINS=http://localhost:5173

# ── CRM Frontend (Vite — prefix VITE_ to expose to browser) ──────────────────
# Full URL of the deployed API server (leave empty to use relative /api in dev)
VITE_API_URL=

# Port for the Vite dev server
PORT=5173

# Base path for the frontend (use / for Vercel, or a sub-path for Replit)
BASE_PATH=/
